{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Fatal Affairs Studio Config",
  "type": "object",
  "properties": {
    "channel": {
      "type": "object",
      "properties": {
        "name": { "const": "Fatal Affairs" },
        "slogan": { "const": "Every Affair Has a Story. Some End in Murder." },
        "colors": {
          "type": "object",
          "properties": {
            "bg": { "const": "#111111" },
            "text": { "const": "#FFFFFF" },
            "accent": { "const": "#A30E15" },
            "gray": { "const": "#4D4D4D" },
            "light_gray": { "const": "#BDBDBD" }
          }
        },
        "fonts": {
          "type": "object",
          "properties": {
            "headline": { "const": "Bebas Neue / Oswald Bold" },
            "body": { "const": "Montserrat" }
          }
        }
      }
    },
    "providers": {
      "type": "object",
      "properties": {
        "voice": { "enum": ["elevenlabs"], "default": "elevenlabs" },
        "voice_id": {
          "const": "wSChTcAxdiTjLPhHeyrM",
          "description": "Jimmy - Canadian Podcast Narration (male, Canadian accent, formal, narrative_story use-case). Verified via live TTS test 2026-07-19 — the MCP tool's silent default produced a female voice, which is wrong for this channel, so voice_id must always be passed explicitly."
        },
        "voice_model": {
          "const": "eleven_multilingual_v2",
          "description": "Stable long-form narration without emotion tags, per this channel's voiceover policy — see Agents/voice_production_agent.md."
        },
        "image": { "enum": ["midjourney", "flux"], "default": "flux" },
        "video_assembly": { "enum": ["remotion"], "default": "remotion" },
        "publish": { "enum": ["youtube_data_api_v3"], "default": "youtube_data_api_v3" }
      }
    },
    "publishing_pace": {
      "type": "object",
      "description": "Encodes the channel owner's own release strategy — see fatal-affairs-project-brief.md",
      "properties": {
        "main_video_and_first_short_same_day": { "const": true },
        "remaining_shorts_one_per_day": { "const": true },
        "shorts_order": { "const": "strongest_hook_first_not_chronological" }
      }
    }
  }
}
