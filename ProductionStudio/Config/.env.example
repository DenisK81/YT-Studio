# Copy to .env, fill with real values, never commit .env
# Load these into n8n's credential store rather than referencing this file directly in production.

ANTHROPIC_API_KEY=

ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=

# default image provider: fal.ai (Flux schnell) — see Tools/image_gen_tool.md
IMAGE_PROVIDER=fal_ai
FAL_KEY=

# optional fallback providers, fill only if you actually wire the fallback path
LEONARDO_API_KEY=
REPLICATE_API_TOKEN=

YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_OAUTH_REFRESH_TOKEN=

GITHUB_TOKEN=
GITHUB_REPO=owner/ProductionStudio

N8N_WEBHOOK_BASE_URL=
REMOTION_RENDER_WORKER_URL=
